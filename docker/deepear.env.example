# DeepEar 独立环境变量模板
# 复制为 docker/deepear.env 并填入真实值

# 模型提供商
LLM_PROVIDER=openrouter
REASONING_MODEL_PROVIDER=openrouter
TOOL_MODEL_PROVIDER=openrouter

# 模型 ID
REASONING_MODEL_ID=openai/gpt-4o-mini
TOOL_MODEL_ID=openai/gpt-4o-mini

# Provider API Keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
JINA_API_KEY=

# 可选：允许哪些父页面 origin 通过 postMessage 注入登录态
# 本机开发可填 http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000
VITE_ALLOWED_PARENT_ORIGINS=
